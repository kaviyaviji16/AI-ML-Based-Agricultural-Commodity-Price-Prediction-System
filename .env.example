# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-super-secret-key-minimum-32-characters!!

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=agri_db
POSTGRES_USER=agri_user
POSTGRES_PASSWORD=agri_pass
DATABASE_URL=postgresql+asyncpg://agri_user:agri_pass@postgres/agri_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── External APIs ─────────────────────────────────────────────────────────────
IMD_API_KEY=your-imd-api-key-here
DATA_GOV_API_KEY=your-data-gov-in-api-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000
